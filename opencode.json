{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "../notopia/**": "allow",
      "./**": "allow"
    }
  },
  "default_agent": "writing",
  "formatter": {
    "typstyle": {
      "command": ["typstyle", "-i", "$FILE"],
      "extensions": [".typ"]
    }
  }
}
